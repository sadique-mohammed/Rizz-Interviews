NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth

NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard

# ─── Database ───────────────────────────────────────
DATABASE_URL=your_neon_database_url_here

# ─── Redis (Upstash) ───────────────────────────────
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ─── AI Provider Keys ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Gemini API Mode ───────────────────────────────
AI_GEMINI_API_MODE=interactions
AI_GEMINI_STORE_INTERACTIONS=false

# ─── Evaluation Model ──────────────────────────────
AI_EVALUATION_PROVIDER=gemini
AI_EVALUATION_MODEL=gemini-3.1-flash-lite
AI_EVALUATION_FALLBACK_MODELS=gemini-2.5-flash-lite,groq:openai/gpt-oss-20b

# ─── Chat Model ────────────────────────────────────
AI_CHAT_PROVIDER=groq
AI_CHAT_MODEL=openai/gpt-oss-120b
AI_CHAT_FALLBACK_MODELS=groq:openai/gpt-oss-20b,gemini:gemini-3.1-flash-lite

# ─── Development Controls ──────────────────────────
AI_DEV_MOCK_MODE=false
AI_DEV_VERBOSE_LOGS=true
AI_FORCE_MODEL_FAILURE=false